# sync_ringcentral_calls.py
import requests
import base64
import json
import os
from datetime import datetime, timedelta
from sqlalchemy import create_engine, text
import logging
import sys
import time
import urllib3

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Configure logging
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')


class RingCentralCallsSync:
    def __init__(self, credential_file="rc-credentials.json"):
        self.credential_file = credential_file
        self.credentials = self.load_credentials()
        self.access_token = None
        self.base_url = None
        self.engine = self.create_db_engine()
        
    def load_credentials(self):
        """Load credentials from JSON file"""
        try:
            with open(self.credential_file, 'r') as f:
                credentials = json.load(f)
            logging.info("Credentials loaded successfully")
            return credentials
        except Exception as e:
            logging.error(f"Failed to load credentials: {e}")
            return None
    
    def create_db_engine(self):
        """Create database engine"""
        try:
            connection_string = f"postgresql://{DB_CONFIG['user']}:{DB_CONFIG['password']}@{DB_CONFIG['host']}:{DB_CONFIG['port']}/{DB_CONFIG['database']}"
            engine = create_engine(connection_string)
            logging.info("Database engine created successfully")
            return engine
        except Exception as e:
            logging.error(f"Failed to create database engine: {e}")
            return None
    
    def get_base_url(self):
        """Determine base URL from credentials"""
        if not self.credentials:
            return None
            
        server = self.credentials.get('server', '').lower()
        if 'sandbox' in server or 'devtest' in server:
            return "https://platform.devtest.ringcentral.com"
        else:
            return "https://platform.ringcentral.com"
    
    def get_jwt_token(self):
        """Get the first available JWT token"""
        if not self.credentials or 'jwt' not in self.credentials:
            return None
            
        jwt_dict = self.credentials['jwt']
        if not jwt_dict:
            return None
            
        # Return the first JWT token available
        first_key = list(jwt_dict.keys())[0]
        return jwt_dict[first_key]
    
    def authenticate(self):
        """Authenticate with RingCentral API"""
        if not self.credentials:
            logging.error("No credentials available")
            return False
            
        client_id = self.credentials.get('clientId')
        client_secret = self.credentials.get('clientSecret')
        jwt_token = self.get_jwt_token()
        
        if not all([client_id, client_secret, jwt_token]):
            logging.error("Missing required credentials")
            return False
            
        self.base_url = self.get_base_url()
        if not self.base_url:
            logging.error("Could not determine base URL")
            return False
            
        # Create authentication header
        auth_string = base64.b64encode(f"{client_id}:{client_secret}".encode()).decode()
        
        headers = {
            'Authorization': f'Basic {auth_string}',
            'Content-Type': 'application/x-www-form-urlencoded'
        }
        
        data = {
            'grant_type': 'urn:ietf:params:oauth:grant-type:jwt-bearer',
            'assertion': jwt_token
        }
        
        try:
            response = requests.post(
                f'{self.base_url}/restapi/oauth/token',
                headers=headers,
                data=data,
                timeout=30,
                verify=False
            )
            
            if response.status_code == 200:
                token_data = response.json()
                self.access_token = token_data['access_token']
                logging.info("Authentication successful")
                return True
            else:
                logging.error(f"Authentication failed: {response.status_code}")
                return False
                
        except Exception as e:
            logging.error(f"Authentication error: {e}")
            return False
    
    def make_api_request(self, endpoint, params=None):
        """Make authenticated API request"""
        if not self.access_token and not self.authenticate():
            return None
            
        headers = {
            'Authorization': f'Bearer {self.access_token}',
            'Accept': 'application/json'
        }
        
        url = f"{self.base_url}{endpoint}"
        
        try:
            response = requests.get(
                url, 
                headers=headers, 
                params=params, 
                timeout=60,
                verify=False
            )
            
            if response.status_code == 200:
                return response.json()
            elif response.status_code == 401:
                logging.warning("Token expired, re-authenticating...")
                if self.authenticate():
                    return self.make_api_request(endpoint, params)
                else:
                    return None
            elif response.status_code == 429:
                logging.warning("Rate limit hit, waiting 60 seconds...")
                time.sleep(60)
                return self.make_api_request(endpoint, params)
            else:
                logging.error(f"API request failed: {response.status_code}")
                return None
                
        except Exception as e:
            logging.error(f"API request error: {e}")
            return None
    
    def get_last_sync_date(self):
        """Get the last sync date from the database"""
        with self.engine.connect() as conn:
            result = conn.execute(text("""
                SELECT MAX(sync_timestamp) FROM pipedrive.fact_ringcentral_calls
            """)).scalar()
            
            if result:
                # Use last sync date minus 1 day to ensure we don't miss any data
                return result - timedelta(days=1)
            else:
                # If no data exists, start from January 1st, 2025
                return datetime(2025, 1, 1)
    
    def fetch_recent_call_logs(self, days_back=1):
        """Fetch only recent call logs for incremental updates"""
        last_sync = self.get_last_sync_date()
        start_date = last_sync
        end_date = datetime.now()
        
        logging.info(f"Fetching calls from {start_date} to {end_date}")
        
        all_calls = []
        page = 1
        
        while True:
            params = {
                'dateFrom': start_date.strftime('%Y-%m-%dT00:00:00.000Z'),
                'dateTo': end_date.strftime('%Y-%m-%dT23:59:59.999Z'),
                'page': page,
                'perPage': 1000,
                'view': 'Detailed'
            }
            
            data = self.make_api_request('/restapi/v1.0/account/~/call-log', params)
            if not data:
                break
                
            calls = data.get('records', [])
            if not calls:
                break
                
            all_calls.extend(calls)
            logging.info(f"Page {page}: Fetched {len(calls)} calls (Total: {len(all_calls)})")
            
            # Check for more pages
            navigation = data.get('navigation', {})
            if not navigation.get('nextPage'):
                break
                
            page += 1
            time.sleep(1.0)  # Rate limiting
            
            if page > 20:  # Limit pages for incremental sync
                logging.warning("Reached page limit for incremental sync")
                break
        
        logging.info(f"Total recent calls fetched: {len(all_calls)}")
        return all_calls
    
    def ensure_table_exists(self):
        """Ensure the fact_ringcentral_calls table exists with correct schema"""
        logging.info("Ensuring table has correct schema...")
        
        with self.engine.connect() as conn:
            try:
                # First check if table exists and get its columns
                result = conn.execute(text("""
                    SELECT column_name 
                    FROM information_schema.columns 
                    WHERE table_schema = 'pipedrive' 
                    AND table_name = 'fact_ringcentral_calls'
                    ORDER BY ordinal_position
                """))
                existing_columns = [row[0] for row in result.fetchall()]
                
                if not existing_columns:
                    # Table doesn't exist, create it
                    create_table_sql = """
                        CREATE TABLE pipedrive.fact_ringcentral_calls (
                            call_id VARCHAR(100) PRIMARY KEY,
                            session_id VARCHAR(100),
                            start_time TIMESTAMP,
                            end_time TIMESTAMP,
                            duration_seconds INTEGER,
                            direction VARCHAR(20),
                            call_type VARCHAR(50),
                            from_number VARCHAR(50),
                            from_name VARCHAR(255),
                            to_number VARCHAR(50),
                            to_name VARCHAR(255),
                            extension_id VARCHAR(100),
                            extension_name VARCHAR(255),
                            call_status VARCHAR(50),
                            recording_url TEXT,
                            sync_timestamp TIMESTAMP WITHOUT TIME ZONE DEFAULT NOW()
                        )
                    """
                    conn.execute(text(create_table_sql))
                    conn.commit()
                    logging.info("Table pipedrive.fact_ringcentral_calls created with full schema")
                else:
                    # Table exists, check for missing columns
                    logging.info(f"Existing columns: {existing_columns}")
                    
                    # Define required columns
                    required_columns = [
                        'call_id', 'session_id', 'start_time', 'end_time', 'duration_seconds',
                        'direction', 'call_type', 'from_number', 'from_name', 'to_number',
                        'to_name', 'extension_id', 'extension_name', 'call_status', 
                        'recording_url', 'sync_timestamp'
                    ]
                    
                    # Add missing columns
                    for column in required_columns:
                        if column not in existing_columns:
                            if column == 'session_id':
                                alter_sql = "ALTER TABLE pipedrive.fact_ringcentral_calls ADD COLUMN session_id VARCHAR(100)"
                            elif column == 'sync_timestamp':
                                alter_sql = "ALTER TABLE pipedrive.fact_ringcentral_calls ADD COLUMN sync_timestamp TIMESTAMP WITHOUT TIME ZONE DEFAULT NOW()"
                            else:
                                # For other columns, you'd need to define the appropriate type
                                continue
                                
                            try:
                                conn.execute(text(alter_sql))
                                conn.commit()
                                logging.info(f"Added missing column: {column}")
                            except Exception as e:
                                logging.warning(f"Could not add column {column}: {e}")
                    
                    logging.info("Table schema is now up to date")
                
            except Exception as e:
                logging.error(f"Failed to ensure table schema: {e}")
    
    def extract_call_data(self, call):
        """Extract call data for database insertion"""
        from_info = call.get('from', {})
        to_info = call.get('to', {})
        extension = call.get('extension', {})
        
        return {
            'call_id': call.get('id'),
            'session_id': call.get('sessionId'),
            'start_time': call.get('startTime'),
            'end_time': call.get('endTime'),
            'duration_seconds': call.get('duration'),
            'direction': call.get('direction'),
            'call_type': call.get('type'),
            'from_number': from_info.get('phoneNumber'),
            'from_name': from_info.get('name'),
            'to_number': to_info.get('phoneNumber'),
            'to_name': to_info.get('name'),
            'extension_id': extension.get('id'),
            'extension_name': extension.get('name'),
            'call_status': call.get('result'),
            'recording_url': call.get('recording', {}).get('contentUri') if call.get('recording') else None
        }
    
    def sync_recent_calls(self):
        """Sync only recent call logs for incremental updates"""
        logging.info("Starting incremental sync of recent calls...")
        
        self.ensure_table_exists()
        calls = self.fetch_recent_call_logs()
        
        if not calls:
            logging.info("No new calls found to sync")
            return True
        
        inserted_count = 0
        updated_count = 0
        error_count = 0
        
        # Process in batches
        batch_size = 500
        total_batches = (len(calls) + batch_size - 1) // batch_size
        
        for batch_num in range(total_batches):
            start_idx = batch_num * batch_size
            end_idx = min((batch_num + 1) * batch_size, len(calls))
            batch_calls = calls[start_idx:end_idx]
            
            logging.info(f"Processing batch {batch_num + 1}/{total_batches} ({len(batch_calls)} calls)")
            
            batch_inserted = 0
            batch_updated = 0
            batch_errors = 0
            
            for call in batch_calls:
                # Create a new connection for each call to avoid transaction issues
                with self.engine.connect() as conn:
                    try:
                        call_data = self.extract_call_data(call)
                        
                        # Check if call already exists
                        existing_record = conn.execute(
                            text("SELECT call_id FROM pipedrive.fact_ringcentral_calls WHERE call_id = :call_id"),
                            {'call_id': call_data['call_id']}
                        ).fetchone()
                        
                        if existing_record:
                            # Update existing call
                            conn.execute(text("""
                                UPDATE pipedrive.fact_ringcentral_calls SET
                                    session_id = :session_id,
                                    start_time = :start_time,
                                    end_time = :end_time,
                                    duration_seconds = :duration_seconds,
                                    direction = :direction,
                                    call_type = :call_type,
                                    from_number = :from_number,
                                    from_name = :from_name,
                                    to_number = :to_number,
                                    to_name = :to_name,
                                    extension_id = :extension_id,
                                    extension_name = :extension_name,
                                    call_status = :call_status,
                                    recording_url = :recording_url,
                                    sync_timestamp = NOW()
                                WHERE call_id = :call_id
                            """), call_data)
                            batch_updated += 1
                            conn.commit()
                        else:
                            # Insert new call
                            conn.execute(text("""
                                INSERT INTO pipedrive.fact_ringcentral_calls (
                                    call_id, session_id, start_time, end_time, duration_seconds, direction, call_type,
                                    from_number, from_name, to_number, to_name, extension_id, extension_name,
                                    call_status, recording_url, sync_timestamp
                                ) VALUES (
                                    :call_id, :session_id, :start_time, :end_time, :duration_seconds, :direction, :call_type,
                                    :from_number, :from_name, :to_number, :to_name, :extension_id, :extension_name,
                                    :call_status, :recording_url, NOW()
                                )
                            """), call_data)
                            batch_inserted += 1
                            conn.commit()
                            
                    except Exception as e:
                        batch_errors += 1
                        if batch_errors <= 3:
                            logging.error(f"Error with call {call.get('id')}: {str(e)[:200]}")
                        continue
            
            inserted_count += batch_inserted
            updated_count += batch_updated
            error_count += batch_errors
            
            logging.info(f"Batch {batch_num + 1}: {batch_inserted} new, {batch_updated} updated, {batch_errors} errors")
        
        # Get final count
        with self.engine.connect() as conn:
            count_after = conn.execute(text("SELECT COUNT(*) FROM pipedrive.fact_ringcentral_calls")).scalar()
        
        logging.info(f"SYNC COMPLETED:")
        logging.info(f"  - New calls inserted: {inserted_count}")
        logging.info(f"  - Existing calls updated: {updated_count}")
        logging.info(f"  - Errors: {error_count}")
        logging.info(f"  - Total in database: {count_after}")
        
        return inserted_count > 0 or updated_count > 0

def main():
    """Main function - Only syncs recent calls"""
    print("RingCentral Calls Sync - Incremental Update")
    print("===========================================")
    print("Only fetching recent calls (incremental update)")
    print("Updating: pipedrive.fact_ringcentral_calls")
    print("===========================================")
    
    # Initialize sync
    sync = RingCentralCallsSync("rc-credentials.json")
    
    # Test authentication
    if not sync.authenticate():
        print("Authentication failed - check your rc-credentials.json file")
        sys.exit(1)
    
    print("Authentication successful")
    
    # Sync recent calls only
    print("Syncing recent calls to pipedrive.fact_ringcentral_calls...")
    success = sync.sync_recent_calls()
    
    if success:
        print("Incremental sync completed successfully!")
        print("Data stored in: pipedrive.fact_ringcentral_calls")
    else:
        print("Sync failed!")
        sys.exit(1)

if __name__ == "__main__":
    main()