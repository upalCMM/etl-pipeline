import os
import sys

# Add parent directory to path
current_dir = os.path.dirname(os.path.abspath(__file__))
parent_dir = os.path.dirname(current_dir)
if parent_dir not in sys.path:
    sys.path.insert(0, parent_dir)

print(f"Current dir: {current_dir}")
print(f"Parent dir: {parent_dir}")
print(f"Python path: {sys.path}")

# Try to import config
try:
    import config
    print("✅ config imported successfully")
    
    # Check for required config variables
    required_vars = ['DB_CONFIG', 'RINGCENTRAL_CLIENT_ID', 'RINGCENTRAL_CLIENT_SECRET']
    for var in required_vars:
        if hasattr(config, var):
            print(f"✅ {var} exists in config")
        else:
            print(f"❌ {var} not found in config")
            
except ImportError as e:
    print(f"❌ Failed to import config: {e}")

# Try to import from the script itself
print("\nTrying to import from sync_ringcentral_final.py...")
try:
    # Read the script and check its imports
    with open('sync_ringcentral_final.py', 'r') as f:
        content = f.read()
    
    # Look for import statements
    import_lines = [line for line in content.split('\n') if line.strip().startswith(('import ', 'from '))]
    print(f"Found {len(import_lines)} import statements")
    
    # Test each import
    for line in import_lines[:5]:  # Test first 5 imports
        line = line.strip()
        print(f"\nTesting: {line}")
        try:
            # Try to execute the import
            exec(line)
            print("  ✅ Import successful")
        except Exception as e:
            print(f"  ❌ Import failed: {e}")
            
except Exception as e:
    print(f"Error: {e}")
