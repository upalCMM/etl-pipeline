# update_ga4_referrer_sessions_incremental.py

import os
import certifi
import pandas as pd
import logging
from datetime import datetime, timedelta
from google.cloud import bigquery
from sqlalchemy import create_engine, text
from config import DB_CONFIG, BIGQUERY_CONFIG

# SSL certificates
os.environ['SSL_CERT_FILE'] = certifi.where()
os.environ['REQUESTS_CA_BUNDLE'] = certifi.where()

# Logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler('ga4_incremental.log', encoding='utf-8'),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

SCHEMA_NAME = 'google_data'
TABLE_NAME = 'ga4_referrer_sessions'


class GA4IncrementalLoader:

    def __init__(self):
        self.bq_client = None
        self.pg_engine = None
        self.setup_clients()

    def setup_clients(self):
        """Initialize BigQuery + Postgres clients."""
        try:
            logger.info("🔌 Connecting to BigQuery...")
            self.bq_client = bigquery.Client.from_service_account_json(
                BIGQUERY_CONFIG['credentials_path'],
                project=BIGQUERY_CONFIG['project']
            )
            logger.info("✅ BigQuery connection established.")

            logger.info("🔌 Connecting to PostgreSQL...")
            pg_url = (
                f"postgresql://{DB_CONFIG['user']}:{DB_CONFIG['password']}"
                f"@{DB_CONFIG['host']}:{DB_CONFIG['port']}/{DB_CONFIG['database']}"
            )
            self.pg_engine = create_engine(pg_url)
            logger.info("✅ PostgreSQL connection established.")

        except Exception as e:
            logger.error(f"❌ Failed to initialize clients: {e}")
            raise

    def get_latest_date_from_postgres(self):
        """Return latest date already loaded in Postgres."""
        try:
            logger.info("📅 Checking the latest loaded GA4 date in Postgres...")
            with self.pg_engine.connect() as conn:
                result = conn.execute(text(f"""
                    SELECT MAX(date) FROM {SCHEMA_NAME}.{TABLE_NAME};
                """))
                max_date = result.scalar()

            if max_date:
                logger.info(f"🔎 Latest date in Postgres: {max_date}")
            else:
                logger.info("🆕 No data found in table — starting from scratch.")

            return max_date

        except Exception as e:
            logger.error(f"❌ Error retrieving latest date: {e}")
            raise

    def run_bigquery_incremental_query(self, start_date):
        """Run GA4 query only for dates AFTER the latest Postgres date."""
        try:
            start_suffix = start_date.strftime("%Y%m%d")
            today_suffix = datetime.today().strftime("%Y%m%d")

            logger.info(f"🚀 Running BigQuery incremental query for dates > {start_date}")
            logger.info(f"BigQuery range: {start_suffix} → {today_suffix}")

            query = f"""
            WITH session_data AS (
              SELECT
                event_date,
                (SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'page_referrer') AS page_referrer,
                (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') AS ga_session_id,
                device.category AS device_type
              FROM `iron-circuit-345510.analytics_266654161.events_*`
              WHERE 
                _TABLE_SUFFIX BETWEEN '{start_suffix}' AND '{today_suffix}'
                
                AND (SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'page_referrer') IN (
                  -- [FULL EXPLICIT URL LIST — EXACTLY SAME AS FULL LOAD]
                  'https://www.comparemymove.com/conveyancing',
                  'https://www.comparemymove.com/conveyancing/remortgage-solicitors',
                  'https://www.comparemymove.com/conveyancing/buy-to-let-conveyancing-solicitors',
                  'https://www.comparemymove.com/conveyancing/freehold-solicitors',
                  'https://www.comparemymove.com/conveyancing/shared-ownership-conveyancers',
                  'https://www.comparemymove.com/conveyancing/solicitors-for-right-to-buy',
                  'https://www.comparemymove.com/conveyancing/solicitors-for-first-time-buyers',
                  'https://www.comparemymove.com/chartered-surveyors',
                  'https://www.comparemymove.com/chartered-surveyors/snagging-survey',
                  'https://www.comparemymove.com/chartered-surveyors/home-report-scotland',
                  'https://www.comparemymove.com/chartered-surveyors/help-to-buy-valuation',
                  'https://www.comparemymove.com/chartered-surveyors/shared-ownership-valuation',
                  'https://www.comparemymove.com/house-removals/long-distance-removals',
                  'https://www.comparemymove.com/house-removals',
                  'https://www.comparemymove.com/man-and-van',
                  'https://www.comparemymove.com/international-removals',
                  'https://www.comparemymove.com/house-clearance',
                  'https://www.comparemymove.com/house-clearance/probate-house-clearance',
                  'https://www.comparemymove.com/house-clearance/bereavement-house-clearance',
                  'https://www.comparemymove.com/probate-services',
                  'https://www.comparemymove.com/will-writing-services',
                  'https://www.comparemymove.com/mortgage-brokers',
                  'http://comparemymove.com',
                  'http://comparemymove.com/guides/surveying',
                  'http://comparemymove.com/guides/conveyancing',
                  'https://www.comparemymove.com/guides/removals',
                  'https://www.comparemymove.com/guides/mortgages-and-deposits',
                  'https://www.comparemymove.com/guides/probate',
                  'https://www.comparemymove.com/guides/will-writing',
                  'https://www.comparemymove.com/conveyancing/conveyancing-calculator',
                  'https://www.comparemymove.com/house-removals/stamp-duty-calculator',
                  'https://www.comparemymove.com/house-removals/help-to-buy-calculator',
                  'https://www.comparemymove.com/conveyancing/leasehold-extension-calculator',
                  'https://www.comparemymove.com/house-removals/cost-of-moving-house-calculator',
                  'https://www.comparemymove.com/directory',
                  'https://www.comparemymove.com/house-removals',
                  'https://www.comparemymove.com/conveyancing',
                  'https://www.comparemymove.com/chartered-surveyors',
                  'https://www.comparemymove.com/house-clearance',
                  'https://www.comparemymove.com/international-removals',
                  'https://www.comparemymove.com/compare/conveyancing',
                  'https://www.comparemymove.com/compare/removals',
                  'https://www.comparemymove.com/compare/surveying',
                  'https://www.comparemymove.com/compare/man-and-van',
                  'https://www.comparemymove.com/compare/international',
                  'https://www.comparemymove.com/compare/clearance',
                  'https://www.comparemymove.com/compare/probate',
                  'https://www.comparemymove.com/compare/wills',
                  'https://www.comparemymove.com/compare/mortgage-brokers/mortgage-stage',
                  'https://www.comparemymove.com/compare/mortgage-brokers/remortgage-value',
                  'https://www.comparemymove.com/about-us/',
                  'https://www.comparemymove.com/press-and-media'
                )

                AND (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') IS NOT NULL
            )

            SELECT
              PARSE_DATE('%Y%m%d', event_date) AS date,
              page_referrer,
              device_type,
              CASE 
                WHEN page_referrer LIKE '%/conveyancing%' THEN 'Conveyancing'
                WHEN page_referrer LIKE '%chartered-surveyors%' THEN 'Surveying'
                WHEN page_referrer LIKE '%removals%' OR page_referrer LIKE '%man-and-van%' THEN 'Removals'
                WHEN page_referrer LIKE '%house-clearance%' THEN 'House Clearance'
                WHEN page_referrer LIKE '%probate%' THEN 'Conveyancing'
                WHEN page_referrer LIKE '%will-writing%' THEN 'Conveyancing'
                WHEN page_referrer LIKE '%mortgage-brokers%' THEN 'Mortgage'
                ELSE 'Other'
              END AS category,
              COUNT(DISTINCT ga_session_id) AS unique_sessions
            FROM session_data
            GROUP BY date, page_referrer, device_type, category
            ORDER BY date ASC;
            """

            df = self.bq_client.query(query).to_dataframe()

            logger.info(f"📥 BigQuery incremental rows returned: {len(df)}")

            return df

        except Exception as e:
            logger.error(f"❌ BigQuery incremental query failed: {e}")
            raise

    def insert_new_rows(self, df):
        """Insert only new rows (incremental load)."""
        if df.empty:
            logger.info("ℹ️ No new rows to insert — GA4 data already up to date.")
            return 0

        df['date'] = pd.to_datetime(df['date']).dt.date

        try:
            logger.info(f"📝 Inserting {len(df)} new rows into Postgres...")

            with self.pg_engine.begin() as conn:
                df.to_sql(
                    TABLE_NAME,
                    conn,
                    schema=SCHEMA_NAME,
                    if_exists='append',
                    index=False,
                    method='multi'
                )

            logger.info("✅ New rows inserted successfully.")
            return len(df)

        except Exception as e:
            logger.error(f"❌ Postgres insert failed: {e}")
            raise

    def run(self):
        """Main pipeline controller."""
        logger.info("=" * 80)
        logger.info("🚀 Starting GA4 incremental update...")

        latest_date = self.get_latest_date_from_postgres()

        if latest_date is None:
            logger.info("⚠️ No existing data — you should run FULL loader first.")
            return

        # Start from next day AFTER latest loaded date
        start_date = latest_date + timedelta(days=1)

        logger.info(f"✨ Incremental start date set to: {start_date}")

        df_new = self.run_bigquery_incremental_query(start_date)

        inserted = self.insert_new_rows(df_new)

        logger.info(f"🎉 Incremental update completed. Rows inserted: {inserted}")
        logger.info("=" * 80)


def main():
    loader = GA4IncrementalLoader()
    loader.run()


if __name__ == "__main__":
    main()
