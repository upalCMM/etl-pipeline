#!/usr/bin/env python3
"""
DAILY UPSERT: Leads data from MariaDB to PostgreSQL.
Only inserts new records (ON CONFLICT DO NOTHING).
Adds services, sub_services, town, and region from dimension tables.
Excludes PII, cancelled, test, and mystery shop leads.
From Jan 2024 onwards.
"""

import os
import sys
from datetime import datetime, date
from urllib.parse import urlparse
from dotenv import load_dotenv
import mysql.connector
import psycopg2
import psycopg2.extras

# Load env
load_dotenv()

# Config
DB_HOST = os.getenv("DB_HOST")
DB_NAME = os.getenv("DB_NAME")
DB_USER = os.getenv("DB_USER")
DB_PASSWORD = os.getenv("DB_PASSWORD")
DB_PORT = os.getenv("DB_PORT")

MARIA_HOST = os.getenv("MARIA_HOST", "127.0.0.1")
MARIA_PORT = os.getenv("MARIA_PORT", "53080")
MARIA_USER = os.getenv("MARIA_USER", "db")
MARIA_PASS = os.getenv("MARIA_PASS", "db")
MARIA_DB = os.getenv("MARIA_DB", "compmove_core")

START_DATE = date(2024, 1, 1)

# Helper functions
def to_bool(val):
    return bool(val) if val is not None else None

def to_decimal(val):
    return float(val) if val is not None else None

def extract_canonical_url(url):
    if not url or not isinstance(url, str):
        return None
    try:
        parsed = urlparse(url)
        parsed = parsed._replace(fragment="", query="")
        canonical = parsed.geturl()
        if canonical.endswith('/'):
            canonical = canonical[:-1]
        canonical = canonical.lower()
        if canonical.startswith('http://www.'):
            canonical = canonical.replace('http://www.', 'http://')
        elif canonical.startswith('https://www.'):
            canonical = canonical.replace('https://www.', 'https://')
        return canonical[:500] if len(canonical) > 500 else canonical
    except:
        return None

def get_dimension_data():
    """Get services, lead_types, and postcode data from MariaDB."""
    try:
        conn = mysql.connector.connect(
            host=MARIA_HOST, port=int(MARIA_PORT),
            user=MARIA_USER, password=MARIA_PASS,
            database=MARIA_DB
        )
        cursor = conn.cursor(dictionary=True)
        
        # Get services
        cursor.execute("SELECT id, name FROM compmove_core.services")
        services = {row['id']: row['name'] for row in cursor.fetchall()}
        
        # Get lead_types
        cursor.execute("SELECT id, name FROM compmove_core.lead_types")
        lead_types = {row['id']: row['name'] for row in cursor.fetchall()}
        
        # Get postcode data (town and region)
        cursor.execute("SELECT id, town, region FROM compmove_core.address_postcodes")
        postcodes = {}
        for row in cursor.fetchall():
            postcodes[row['id']] = {
                'town': row['town'],
                'region': row['region']
            }
        
        cursor.close()
        conn.close()
        
        print(f"  Services: {len(services):,} | Lead Types: {len(lead_types):,} | Postcodes: {len(postcodes):,}")
        
        return services, lead_types, postcodes
    except Exception as e:
        print(f"[ERROR] Dimension data: {e}")
        return {}, {}, {}

def get_existing_ids():
    """Get existing lead IDs from PostgreSQL."""
    try:
        conn = psycopg2.connect(
            host=DB_HOST, port=DB_PORT,
            database=DB_NAME, user=DB_USER,
            password=DB_PASSWORD
        )
        cursor = conn.cursor()
        cursor.execute("SELECT id FROM crm_data.leads")
        existing_ids = {row[0] for row in cursor.fetchall()}
        cursor.close()
        conn.close()
        return existing_ids
    except Exception as e:
        print(f"[ERROR] Existing IDs: {e}")
        return set()

def extract_new_leads(existing_ids, services, lead_types, postcodes):
    """Extract only new leads from MariaDB."""
    try:
        conn = mysql.connector.connect(
            host=MARIA_HOST, port=int(MARIA_PORT),
            user=MARIA_USER, password=MARIA_PASS,
            database=MARIA_DB
        )
        cursor = conn.cursor(dictionary=True)
        
        query = """
        SELECT 
            l.id, l.previous_id, l.service_id, l.lead_type_id, l.lead_subtype_id,
            l.postcode_id, l.user_id, l.quote_id,
            l.opt_in, l.http_referrer, l.referrer_url, l.referrer_source_id,
            l.previous_lead_id, l.matches, l.conversion_value, l.estimated_value,
            l.cancelled, l.mystery_shop, l.test_lead, l.created_at, l.updated_at,
            l.obfuscated_at, l.no_competition_lead, l.form_url, l.resell_optout,
            l.resold_at, l.uuid, l.multi_submission
        FROM leads l
        WHERE l.created_at >= %s
          AND COALESCE(l.cancelled, 0) = 0
          AND COALESCE(l.test_lead, 0) = 0
          AND COALESCE(l.mystery_shop, 0) = 0
        ORDER BY l.created_at DESC
        """
        
        cursor.execute(query, (START_DATE,))
        
        new_rows = []
        total_checked = 0
        batch_size = 10000
        
        while True:
            batch = cursor.fetchmany(batch_size)
            if not batch:
                break
            
            for row in batch:
                total_checked += 1
                if row['id'] not in existing_ids:
                    # Add dimension data
                    row['services'] = services.get(row['service_id'])
                    row['sub_services'] = lead_types.get(row['lead_type_id'])
                    
                    # Add town and region from postcodes
                    postcode_data = postcodes.get(row['postcode_id'])
                    if postcode_data:
                        row['town'] = postcode_data['town']
                        row['region'] = postcode_data['region']
                    else:
                        row['town'] = None
                        row['region'] = None
                    
                    new_rows.append(row)
            
            if total_checked % 50000 == 0:
                print(f"  Checked {total_checked:,} rows, found {len(new_rows):,} new")
        
        cursor.close()
        conn.close()
        
        print(f"[INFO] Total checked: {total_checked:,}")
        print(f"[INFO] New rows to insert: {len(new_rows):,}")
        
        return new_rows
        
    except Exception as e:
        print(f"[ERROR] Extract new leads: {e}")
        return None

def transform_data(rows):
    """Transform for PostgreSQL."""
    if not rows:
        return []
    
    transformed = []
    for row in rows:
        try:
            transformed.append((
                row['id'],
                row['previous_id'],
                row['service_id'],
                row['lead_type_id'],
                row['lead_subtype_id'],
                row['postcode_id'],
                row['user_id'],
                row['quote_id'],
                row.get('services'),
                row.get('sub_services'),
                row.get('town'),      # New column
                row.get('region'),    # New column
                to_bool(row['opt_in']),
                row['http_referrer'],
                row['referrer_url'],
                extract_canonical_url(row.get('http_referrer')),
                extract_canonical_url(row.get('referrer_url')),
                row['referrer_source_id'],
                row['previous_lead_id'],
                row['matches'],
                row['conversion_value'],
                to_decimal(row['estimated_value']),
                to_bool(row['cancelled']),
                to_bool(row['mystery_shop']),
                to_bool(row['test_lead']),
                row['created_at'],
                row['updated_at'],
                row['obfuscated_at'],
                to_bool(row.get('no_competition_lead')),
                row['form_url'],
                to_bool(row['resell_optout']),
                row['resold_at'],
                row['uuid'],
                to_bool(row.get('multi_submission'))
            ))
        except Exception as e:
            print(f"  [WARNING] Row {row.get('id')}: {e}")
            continue
    
    return transformed

def upsert_to_postgresql(data):
    """UPSERT new data to PostgreSQL."""
    if not data:
        print("[INFO] No new data to upsert")
        return True
    
    try:
        conn = psycopg2.connect(
            host=DB_HOST, port=DB_PORT,
            database=DB_NAME, user=DB_USER,
            password=DB_PASSWORD
        )
        cursor = conn.cursor()
        
        insert_sql = """
        INSERT INTO crm_data.leads (
            id, previous_id, service_id, lead_type_id, lead_subtype_id,
            postcode_id, user_id, quote_id, services, sub_services,
            town, region,  -- New columns
            opt_in, http_referrer, referrer_url, canonical_http_referrer,
            canonical_referrer_url, referrer_source_id, previous_lead_id,
            matches, conversion_value, estimated_value, cancelled,
            mystery_shop, test_lead, created_at, updated_at, obfuscated_at,
            no_competition_lead, form_url, resell_optout, resold_at,
            uuid, multi_submission
        ) VALUES %s
        ON CONFLICT (id) DO NOTHING
        """
        
        # Batch insert
        psycopg2.extras.execute_values(
            cursor, insert_sql, data,
            template=None, page_size=1000
        )
        
        conn.commit()
        
        print(f"[SUCCESS] Upserted {len(data):,} new rows")
        
        # Get stats
        cursor.execute("SELECT COUNT(*) FROM crm_data.leads")
        total = cursor.fetchone()[0]
        print(f"[INFO] Total rows in table: {total:,}")
        
        # Optional: Show town/region stats for new data
        cursor.execute("""
            SELECT 
                COUNT(*) as total,
                COUNT(town) as with_town,
                COUNT(region) as with_region
            FROM crm_data.leads 
            WHERE town IS NOT NULL OR region IS NOT NULL
        """)
        stats = cursor.fetchone()
        print(f"[INFO] Leads with location data: {stats[0]:,} (town: {stats[1]:,}, region: {stats[2]:,})")
        
        cursor.close()
        conn.close()
        
        return True
        
    except Exception as e:
        print(f"[ERROR] Upsert failed: {e}")
        return False

def main():
    """Main daily upsert process."""
    print(f"\n{'='*60}")
    print(f"DAILY LEADS UPSERT - {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"{'='*60}")
    print(f"Source: MariaDB ({MARIA_HOST}:{MARIA_PORT}/{MARIA_DB})")
    print(f"Target: PostgreSQL ({DB_HOST}:{DB_PORT}/{DB_NAME})")
    print(f"From: {START_DATE} | Excluding: cancelled/test/mystery")
    print(f"New columns: town, region")
    print(f"{'='*60}")
    
    start_time = datetime.now()
    
    # 1. Get dimension data (now includes postcodes)
    print(f"\n[1/4] Getting dimension data...")
    services, lead_types, postcodes = get_dimension_data()
    
    # 2. Get existing IDs from PostgreSQL
    print(f"\n[2/4] Getting existing IDs from PostgreSQL...")
    existing_ids = get_existing_ids()
    print(f"  Existing records: {len(existing_ids):,}")
    
    # 3. Extract only new leads from MariaDB
    print(f"\n[3/4] Extracting new leads from MariaDB...")
    new_leads = extract_new_leads(existing_ids, services, lead_types, postcodes)
    
    if not new_leads:
        print("[DONE] No new leads to insert")
        return True
    
    # 4. Transform data
    print(f"\n[4/4] Processing {len(new_leads):,} new leads...")
    transformed = transform_data(new_leads)
    
    if not transformed:
        print("[DONE] No data after transformation")
        return True
    
    # 5. UPSERT to PostgreSQL
    success = upsert_to_postgresql(transformed)
    
    # Summary
    end_time = datetime.now()
    duration = end_time - start_time
    
    print(f"\n{'='*60}")
    if success:
        print(f"✅ DAILY UPSERT COMPLETED SUCCESSFULLY")
    else:
        print(f"❌ DAILY UPSERT FAILED")
    
    print(f"{'='*60}")
    print(f"Start: {start_time.strftime('%H:%M:%S')}")
    print(f"End:   {end_time.strftime('%H:%M:%S')}")
    print(f"Duration: {duration}")
    print(f"New leads inserted: {len(transformed):,}")
    print(f"{'='*60}")
    
    return success

if __name__ == "__main__":
    try:
        # Check .env
        if not os.path.exists('.env'):
            print("[ERROR] .env file not found")
            sys.exit(1)
        
        # Run
        success = main()
        
        if success:
            sys.exit(0)
        else:
            sys.exit(1)
            
    except KeyboardInterrupt:
        print("\n⚠️  Interrupted by user")
        sys.exit(2)
    except Exception as e:
        print(f"\n💥 Unexpected error: {e}")
        sys.exit(1)