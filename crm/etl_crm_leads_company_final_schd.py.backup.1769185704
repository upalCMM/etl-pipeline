#!/usr/bin/env python3
"""
DAILY UPSERT: Leads Company data from MariaDB to PostgreSQL.
Only inserts new records (ON CONFLICT DO NOTHING).
From Jan 2024 onwards.
"""

import os
import sys
from datetime import datetime, date
from dotenv import load_dotenv
import mysql.connector
import psycopg2
import psycopg2.extras

# Load env
load_dotenv(dotenv_path=os.path.join(os.path.dirname(os.path.abspath(__file__)), '..', '.env'))

# Config
DB_HOST = os.getenv("DB_HOST")
DB_NAME = os.getenv("DB_NAME")
DB_USER = os.getenv("DB_USER")
DB_PASSWORD = os.getenv("DB_PASSWORD")
DB_PORT = os.getenv("DB_PORT")

MARIA_HOST = os.getenv("MARIA_HOST", "127.0.0.1")
MARIA_PORT = os.getenv("MARIA_PORT", "53080")
MARIA_USER = os.getenv("MARIA_USER", "db")
MARIA_PASS = os.getenv("MARIA_PASS", "db")
MARIA_DB = os.getenv("MARIA_DB", "compmove_core")

START_DATE = date(2024, 1, 1)

# Helper functions
def to_bool(val):
    return bool(val) if val is not None else None

def get_existing_ids():
    """Get existing leads_company IDs from PostgreSQL."""
    try:
        conn = psycopg2.connect(
            host=DB_HOST, port=DB_PORT,
            database=DB_NAME, user=DB_USER,
            password=DB_PASSWORD
        )
        cursor = conn.cursor()
        cursor.execute("SELECT id FROM crm_data.leads_company")
        existing_ids = {row[0] for row in cursor.fetchall()}
        cursor.close()
        conn.close()
        print(f"  Existing records in PostgreSQL: {len(existing_ids):,}")
        return existing_ids
    except Exception as e:
        print(f"[ERROR] Getting existing IDs: {e}")
        return set()

def extract_new_leads_company(existing_ids):
    """Extract only new leads_company records from MariaDB."""
    try:
        conn = mysql.connector.connect(
            host=MARIA_HOST, port=int(MARIA_PORT),
            user=MARIA_USER, password=MARIA_PASS,
            database=MARIA_DB
        )
        cursor = conn.cursor(dictionary=True)
        
        query = """
        SELECT 
            id, previous_id, service_id, lead_type_id, lead_subtype_id,
            company_id, lead_id, previous_lead_id, lead_profile_id,
            successful, created_at, updated_at, won, won_set_at
        FROM leads_company
        WHERE created_at >= %s
        ORDER BY created_at DESC
        """
        
        cursor.execute(query, (START_DATE,))
        
        new_rows = []
        total_checked = 0
        batch_size = 10000
        
        while True:
            batch = cursor.fetchmany(batch_size)
            if not batch:
                break
            
            for row in batch:
                total_checked += 1
                if row['id'] not in existing_ids:
                    new_rows.append(row)
            
            if total_checked % 50000 == 0:
                print(f"  Checked {total_checked:,} rows, found {len(new_rows):,} new")
        
        cursor.close()
        conn.close()
        
        print(f"[INFO] Total MariaDB rows checked: {total_checked:,}")
        print(f"[INFO] New rows to insert: {len(new_rows):,}")
        
        return new_rows
        
    except Exception as e:
        print(f"[ERROR] Extract new leads_company: {e}")
        return None

def transform_leads_company_data(rows):
    """Transform leads_company data for PostgreSQL."""
    if not rows:
        return []
    
    transformed = []
    skipped = 0
    
    for row in rows:
        try:
            # Handle MySQL tinyint(1) to PostgreSQL boolean
            successful = to_bool(row['successful'])
            won = to_bool(row['won'])
            
            transformed.append((
                row['id'],
                row['previous_id'],
                row['service_id'],
                row['lead_type_id'],
                row['lead_subtype_id'],
                row['company_id'],
                row['lead_id'],
                row['previous_lead_id'],
                row['lead_profile_id'],
                successful,
                row['created_at'],
                row['updated_at'],
                won,
                row['won_set_at']
            ))
        except Exception as e:
            print(f"  [WARNING] Skipping row {row.get('id')}: {e}")
            skipped += 1
            continue
    
    if skipped > 0:
        print(f"  [INFO] Skipped {skipped} rows due to transformation errors")
    
    return transformed

def upsert_leads_company_to_postgresql(data):
    """UPSERT new leads_company data to PostgreSQL."""
    if not data:
        print("[INFO] No new data to upsert")
        return True
    
    try:
        conn = psycopg2.connect(
            host=DB_HOST, port=DB_PORT,
            database=DB_NAME, user=DB_USER,
            password=DB_PASSWORD
        )
        cursor = conn.cursor()
        
        insert_sql = """
        INSERT INTO crm_data.leads_company (
            id, previous_id, service_id, lead_type_id, lead_subtype_id,
            company_id, lead_id, previous_lead_id, lead_profile_id,
            successful, created_at, updated_at, won, won_set_at
        ) VALUES %s
        ON CONFLICT (id) DO NOTHING
        """
        
        # Batch insert
        psycopg2.extras.execute_values(
            cursor, insert_sql, data,
            template=None, page_size=1000
        )
        
        rows_inserted = cursor.rowcount
        conn.commit()
        
        print(f"[SUCCESS] Inserted {rows_inserted:,} new rows")
        
        # Get updated stats
        cursor.execute("SELECT COUNT(*) FROM crm_data.leads_company")
        total = cursor.fetchone()[0]
        print(f"[INFO] Total rows in table: {total:,}")
        
        # Get date range of inserted data
        if data:
            min_date = min(row[10] for row in data)  # created_at is at index 10
            max_date = max(row[10] for row in data)
            print(f"[INFO] Inserted data range: {min_date} to {max_date}")
        
        cursor.close()
        conn.close()
        
        return True
        
    except Exception as e:
        print(f"[ERROR] Upsert failed: {e}")
        return False

def verify_table_structure():
    """Quick check that table exists."""
    try:
        conn = psycopg2.connect(
            host=DB_HOST, port=DB_PORT,
            database=DB_NAME, user=DB_USER,
            password=DB_PASSWORD
        )
        cursor = conn.cursor()
        
        # Check if table exists
        cursor.execute("""
            SELECT EXISTS (
                SELECT FROM information_schema.tables 
                WHERE table_schema = 'crm_data' 
                AND table_name = 'leads_company'
            )
        """)
        table_exists = cursor.fetchone()[0]
        
        if not table_exists:
            print("[ERROR] Table crm_data.leads_company does not exist!")
            return False
        
        # Check if we have any data
        cursor.execute("SELECT COUNT(*) FROM crm_data.leads_company")
        count = cursor.fetchone()[0]
        print(f"[INFO] Table exists with {count:,} existing rows")
        
        cursor.close()
        conn.close()
        return True
        
    except Exception as e:
        print(f"[ERROR] Verifying table: {e}")
        return False

def main():
    """Main daily upsert process for leads_company."""
    print(f"\n{'='*60}")
    print(f"DAILY LEADS_COMPANY UPSERT - {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"{'='*60}")
    print(f"Source: MariaDB ({MARIA_HOST}:{MARIA_PORT}/{MARIA_DB})")
    print(f"Target: PostgreSQL ({DB_HOST}:{DB_PORT}/{DB_NAME})")
    print(f"Schema: crm_data.leads_company")
    print(f"Start Date: {START_DATE}")
    print(f"{'='*60}")
    
    start_time = datetime.now()
    
    # 1. Verify table exists
    print(f"\n[1/4] Verifying PostgreSQL table...")
    if not verify_table_structure():
        return False
    
    # 2. Get existing IDs from PostgreSQL
    print(f"\n[2/4] Getting existing IDs from PostgreSQL...")
    existing_ids = get_existing_ids()
    
    # 3. Extract only new records from MariaDB
    print(f"\n[3/4] Extracting new leads_company from MariaDB...")
    new_records = extract_new_leads_company(existing_ids)
    
    if new_records is None:
        print("[ERROR] Failed to extract data from MariaDB")
        return False
    
    if not new_records:
        print("[DONE] No new records to insert")
        return True
    
    # 4. Transform data
    print(f"\n[4/4] Processing {len(new_records):,} new records...")
    transformed = transform_leads_company_data(new_records)
    
    if not transformed:
        print("[DONE] No data after transformation")
        return True
    
    # 5. UPSERT to PostgreSQL
    success = upsert_leads_company_to_postgresql(transformed)
    
    # Summary
    end_time = datetime.now()
    duration = end_time - start_time
    
    print(f"\n{'='*60}")
    if success:
        print(f"✅ DAILY UPSERT COMPLETED SUCCESSFULLY")
    else:
        print(f"❌ DAILY UPSERT FAILED")
    
    print(f"{'='*60}")
    print(f"Start: {start_time.strftime('%H:%M:%S')}")
    print(f"End:   {end_time.strftime('%H:%M:%S')}")
    print(f"Duration: {duration}")
    print(f"New records inserted: {len(transformed):,}")
    print(f"{'='*60}")
    
    return success

if __name__ == "__main__":
    try:
        # Check .env
        if not os.path.exists(os.path.join(os.path.dirname(os.path.abspath(__file__)), '..', '.env')):
            print("[ERROR] .env file not found")
            sys.exit(1)
        
        # Run
        success = main()
        
        if success:
            sys.exit(0)
        else:
            sys.exit(1)
            
    except KeyboardInterrupt:
        print("\n⚠️  Interrupted by user")
        sys.exit(2)
    except Exception as e:
        print(f"\n💥 Unexpected error: {e}")
        sys.exit(1)
